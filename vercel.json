{
  "builds": [
    {
      "src": "API/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "前端/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "API/index.py" },
    { "src": "/(.*)", "dest": "前端/dist/$1" }
  ]
}

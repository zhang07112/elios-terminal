{
  "services": [
    {
      "name": "backend",
      "path": "backend",
      "buildCommand": "pip install -r requirements.txt",
      "startCommand": "uvicorn main:app --host 0.0.0.0 --port $PORT"
    },
    {
      "name": "frontend",
      "path": "frontend",
      "buildCommand": "npm install && npm run build",
      "outputDir": "dist",
      "type": "static"
    }
  ]
}
